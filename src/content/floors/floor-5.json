  "npcs": [
    {
      "id": "ossian",
      "name": "Ossian",
      "title": "the sluice-keeper",
      "x": 2,
      "y": 7,
      "greeting": "A stooped man in oiled leathers looks up from a valve wheel. 'Living ones. Rare, down here. I am Ossian — I keep the water moving so it doesn't... pool.'",
      "returnGreeting": "Ossian nods at the wheel. 'Still turning. Still ahead of it, I hope.'",
      "topics": [
        {
          "key": "sluice",
          "response": "'This cistern was built to drain the crypt above. Now it drains something else. The gate east holds a key — sluice-key, I call it. No locks stand between you and it.'"
        },
        {
          "key": "current",
          "response": "'Don't fight the undertow — it only pulls harder. And don't trust the calm patches either. Calm is just where it's already taken what it wanted.'"
        },
        {
          "key": "vault",
