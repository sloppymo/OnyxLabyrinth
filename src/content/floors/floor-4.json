  "npcs": [
    {
      "id": "vesper-cantor",
      "name": "Vesper",
      "title": "the last cantor",
      "x": 2,
      "y": 10,
      "greeting": "A pale woman in choir vestments raises a slate and writes: 'I am Vesper. He took my voice for the choir. I stayed to keep the quiet honest.'",
      "returnGreeting": "Vesper looks up from her slate and taps it twice — her way of saying you are still welcome.",
      "topics": [
        {
          "key": "choir",
          "response": "She writes: 'Forty of us sang here. The Headmaster wanted our voices for his Echo — so he took them, one hymn at a time. What is left of the choir walks the nave in armor now.'"
        },
        {
          "key": "silence",
          "response": "She writes: 'The silence is not empty. Down the nave's center aisle, and on the altar below, he carved runes that swallow spellcraft whole. Keep your casters off the marked stones.'"
        },
        {
          "key": "sanctum",
          "response": "She writes: 'Both doors answer to keys cut on this floor. The choir door's key drowned with the old font, south of here. The sanctum's waits in the loft, where the light does not go.'"
