  "npcs": [
    {
      "id": "drill-sergeant",
      "name": "Old Marta",
      "title": "retired drill sergeant",
      "x": 3,
      "y": 4,
      "greeting": "Hah! Fresh meat for the practice halls. Mind the dart wall.",
      "returnGreeting": "Still standing? Good.",
      "topics": [
        {
          "key": "halls",
          "response": "These halls were carved to train crypt delvers. The east wing is locked — the brass key sits with the old bones in the gallery."
        },
        {
          "key": "water",
          "response": "That pool by the entry is blessed. Take a dip if you're hurting."
        },
        {
          "key": "marta",
          "response": "Thirty years of drills. Now I just haunt the place.",
          "hidden": true
        }
      ],
